DATABASE_URL=
PORT=3001
JWT_SECRET=
# Required on Vercel (and anywhere NODE_ENV=production / VERCEL=1). Use a long random string, e.g. openssl rand -hex 32
# Must match app.json → expo.ios.bundleIdentifier (Apple identity token `aud` claim)
APPLE_BUNDLE_ID=com.colortrack.app
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
ALLOW_PUBLIC_REGISTER=
DISABLE_AUTH=
# Публичен URL на API (за медия R2 links). На Vercel задай реалния домейн на деплоя на backend.
API_PUBLIC_URL=https://your-backend.vercel.app

# Vercel: Settings → General → Root Directory = backend
# Environment Variables: DATABASE_URL, JWT_SECRET, R2_*, APPLE_BUNDLE_ID, ALLOW_PUBLIC_REGISTER, …

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Само за диагностика: сложи 1 във Vercel env, ределой, виж JSON отговорите с `debug`/`detail`, после махни.
# COLORTRACK_API_DEBUG=1
